<?xml version="1.0"?>
<ruleset name="WooAgenticCheckout">
    <description>PHP CodeSniffer rules for Woo Agentic Checkout</description>

    <!-- Scan these directories -->
    <file>./</file>

    <!-- Ignore these -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/blog/*</exclude-pattern>
    <exclude-pattern>*/dist/*</exclude-pattern>

    <!-- PHPCS version & colors -->
    <arg name="colors"/>
    <arg name="extensions" value="php"/>
    <arg value="sp"/>

    <!-- Use WordPress-Extended as base -->
    <rule ref="WordPress-Extra">
        <!-- Allow short ternary -->
        <exclude name="WordPress.PHP.DisallowShortTernary"/>
        <!-- Yoda conditions are ugly for agent code -->
        <exclude name="WordPress.PHP.YodaConditions"/>
        <!-- Allow inline comments without full stop -->
        <exclude name="Squiz.Commenting.InlineComment.InvalidEndChar"/>
    </rule>

    <rule ref="WordPress-Docs"/>

    <!-- Strict type checks for PHP 8.0+ -->
    <rule ref="Generic.PHP.RequireStrictTypes"/>
    <rule ref="PEAR.Functions.ValidDefaultValue"/>

    <!-- Minimum PHP version -->
    <config name="minimum_supported_wp_version" value="6.0"/>
    <config name="testVersion" value="8.0-"/>
    <rule ref="PHPCompatibilityWP">
        <config name="minimum_supported_wp_version" value="6.0"/>
    </rule>
</ruleset>
